{"last_chapter_rule":"","pageList":[],"title":"91看电视","author":"亮亮先森UX&蓝莓果酱UX","version":20251021,"type":"all","url":"http://sj.91kds.cn/api/get_channel.php?id=fyAll","col_type":"icon_2_round","class_name":"央视&卫视&高清&4K&影视&体育&动漫&财经&综艺&教育&新闻&纪录&国际&网络&购物&虎牙","class_url":"央视&卫视&高清&4K&影视&体育&动漫&财经&综艺&教育&新闻&纪录&国际&网络&购物&虎牙","area_name":"安徽&北京&重庆&福建&甘肃&湖北&湖南&吉林&江苏&江西&辽宁&内蒙古&宁夏&青海&山东&山西&陕西&上海&贵州&海南&河北&河南&黑龙江&天津&新疆&西藏&云南&浙江&广西&广东&四川","area_url":"安徽&北京&重庆&福建&甘肃&湖北&湖南&吉林&江苏&江西&辽宁&内蒙古&宁夏&青海&山东&山西&陕西&上海&贵州&海南&河北&河南&黑龙江&天津&新疆&西藏&云南&浙江&广西&广东&四川","sort_name":"","year_name":"","sort_url":"","year_url":"","find_rule":"js:\n/*\n旧域名：\nhttp://www.91kds.org\n\n更新日志：\n2025.10.21 by 另一个书友圈\n- 支持多个键的header，适配海阔headers格式\n2025.10.20 by 另一个书友圈\n- 重构lazy代码\n- 修复线路名错误\n- 添加kdsvod的ua，优化referer的混乱逻辑\n- 添加完整path，移除key去重判断，现在可以观看所有线路，且不重复\n- 已知问题：个别线路需要点击嗅探，如果实现相关逻辑，多线路会拖慢加载。不能因为那一两个链接，影响另外几十个线路，因此舍弃相关线路。\n2025.10.19 by 另一个书友圈\n- 修复多线路referer格式\n2025.10.19 by 老泰\n- 添加图标\n2025.09.20 by 烟水淼淼\n- 取消二级，直接多线路播放\n\n*/\nvar res = {};\nvar items = [];\neval(getCryptoJS());\nCryptoJS\nvar nwtime = parseInt(new Date().getTime() / 1000) + '';\nvar html = getResCode();\n\nif (/ename/.test(html)) {\n    var list = JSON.parse(html);\n    for (var i = 0; i < list.length; i++) {\n        var title = list[i].name;\n        var enamee = list[i].ename;\n        var srcKey = enamee + \"com.jiaoxiang.fangnaleahkajfkahlajjaflfakhfakfbuyaozaigaolefuquqikangbuzhu2.3.4fu:ck:92:92:ff\" + nwtime + \"20240918\";\n        var sign = CryptoJS.MD5(srcKey).toString(CryptoJS.enc.Hex);\n        var url = \"http://sjapi1.91kds.cn/api/get_source.php?ename=\" + enamee + \"&app=com.jiaoxiang.fangnale\" +\n            \"&version=2.3.4\" +\n            \"&mac=fu:ck:92:92:ff\" +\n            \"&nwtime=\" + nwtime +\n            \"&sign=\" + sign +\n            \"&ev=20240918\";\n        items.push({\n            title: title,\n            url: $(url).lazyRule((url) => {\n                var names = [],\n                    urls = [],\n                    headers = [];\n                var html = fetchPC(url);\n                var metadata = JSON.parse(html);\n                var list = metadata.liveSource;\n                var sourceNames = metadata.liveSourceName;\n                var toastLines = []; // 收集 action=play 的线路\n                eval(getCryptoJS());\n\n                for (var j = 0; j < list.length; j++) {\n                    var rawInput = list[j];\n                    var input = rawInput.replace(/^kdsvod:\\/\\//, '');\n\n                    var finalUrl = '';\n                    var headerObj = {};\n\n                    // 正则匹配所有 @@key=value@@ 形式\n                    var reHeaders = input.match(/@@(.*?)@@/g);\n                    if (reHeaders) {\n                        reHeaders.forEach(item => {\n                            var kv = item.slice(2, -2).split('@'); // 去掉 @@ 两边，再按 @ 分割\n                            kv.forEach(pair => {\n                                var idx = pair.indexOf('=');\n                                if (idx > -1) {\n                                    var key = pair.slice(0, idx).trim();\n                                    var value = pair.slice(idx + 1).trim();\n                                    if (/^ua$/i.test(key) || /^user-agent$/i.test(key)) key = 'User-Agent';\n                                    headerObj[key] = value;\n                                }\n                            });\n                            // 如果是 action=play，记录 toast\n                            if (/action=play/i.test(item)) {\n                                action = 'play';\n                                toastLines.push(j + 1); // 收集线路序号\n                            }\n                            // 从 input 中移除这段\n                            input = input.replace(item, '');\n                        });\n                    }\n\n                    // ksdvod 默认 UA\n                    if (rawInput.startsWith('kdsvod://') && !headerObj['User-Agent']) {\n                        headerObj['User-Agent'] = 'AppleCoreMedia/1.0.0.16F79 (iPhone; U; CPU OS 11_5 like Mac OS X; zh_cn)';\n                    }\n\n                    // 海阔 headers 格式\n                    for (var key in headerObj) {\n                        headerObj[key] = headerObj[key].replace(/;/g, '；；');\n                    }\n\n                    if (input.includes('pwd=jsdecode') && input.includes('id=')) {\n                        var parts = input.split('?');\n                        var baseUrl = parts[0];\n                        var queryStr = parts[1] || '';\n                        var queryObj = {};\n                        queryStr.split('&').forEach(kv => {\n                            var t = kv.split('=');\n                            if (t[0]) queryObj[t[0]] = decodeURIComponent(t[1] || '');\n                        });\n                        delete queryObj['pwd']; // 删除 pwd\n                        var id = queryObj['id'];\n                        var bt = queryObj['bt'] || null;\n\n                        var params = {\n                            app: 'com.jiaoxiang.fangnale',\n                            version: '2.3.4',\n                            mac: 'fu:ck:92:92:ff',\n                            utk: '',\n                            nwtime: Math.floor(Date.now() / 1000),\n                            ev: '20250113'\n                        };\n                        var appendStr = 'ahkajfkahlajjaflfakhfakfbuyaozaigaolefuquqikangbuzhu';\n                        var signStr = id;\n                        for (var key in params) {\n                            if (key === 'app') signStr += params[key] + appendStr;\n                            else signStr += params[key];\n                        }\n                        params.sign = CryptoJS.MD5(signStr).toString(CryptoJS.enc.Hex);\n\n                        var finalQuery = [];\n                        for (var k in queryObj) finalQuery.push(k + '=' + encodeURIComponent(queryObj[k]));\n                        for (var k in params) finalQuery.push(k + '=' + encodeURIComponent(params[k]));\n                        finalUrl = baseUrl + '?' + finalQuery.join('&');\n\n                    } else {\n                        var videoUrl = input.startsWith('htmlplay://') ?\n                            input.replace('htmlplay://', 'video://').split('#')[0] :\n                            input;\n                        finalUrl = videoUrl.startsWith('video://') ? videoUrl : (videoUrl + '#isVideo=true');\n                    }\n\n                    names.push('线路' + (j + 1) + ':' + sourceNames[j]);\n                    urls.push(finalUrl);\n                    headers.push(headerObj);\n                }\n                // 循环外统一提示\n                if (toastLines.length) {\n                    toast('线路' + toastLines.join('、') + '是点击嗅探，暂无法播放');\n                }\n                /*log(JSON.stringify({\n                    names,\n                    urls,\n                    headers\n                }));*/\n                return {\n                    names,\n                    urls,\n                    headers\n                };\n            }, url),\n            img: list[i].icon\n        });\n    }\n}\n\nres.data = items;\nsetHomeResult(res);","searchFind":"js:\nvar res = {};\r\nvar items = [];\r\neval(getCryptoJS());\r\nvar nwtime = parseInt(new Date().getTime() / 1000) + '';\r\nvar srcKey = \"4954af3c86d8bc0b766afee71503d860\" + nwtime + \"f8dd806a73202456eb6e782c1c4aecfc\";\r\nvar sign = CryptoJS.MD5(srcKey).toString(CryptoJS.enc.Hex);\r\n\r\nvar html = getResCode();\r\nif (/ename/.test(html)) {\r\n    var list = JSON.parse(html);\r\n    for (var i = 0; i < list.length; i++) {\r\n        var title = list[i].name;\r\n        var img = list[i].icon;\r\n        var desc = list[i].path;\r\n        var url = 'video://http://sj.91kds.cn/api/get_source.php?ename=' + list[i].ename + '&deviceId=ffffffff-da12-5a9f-0000-00002bc63564&imei=483248965895528&key=' + sign + '&tm=' + nwtime + '&desc=广东省广州市移动&mac=&version=2.1.3&isHaveFile=no&userToken=&netType=wifi&app=91ktv&channel=umeng';\r\n\r\n        items.push({\r\n            title: title,\r\n            pic_url: img,\r\n            url: url,\r\n            desc: desc,\r\n        });\r\n    }\r\n}\r\nlog(items);\r\nres.data = items;\r\nsetHomeResult(res);","search_url":"http://sj.91kds.cn/api/get_search.php?id=**&deviceId=ffffffff-da12-5a9f-0000-00002bc63564&imei=483248965895528&key=.js:getVar('kdskey')&tm=.js:getVar('kdstime')&desc=广东省广州市移动&mac=&version=2.1.3&isHaveFile=no&userToken=&netType=wifi&app=91ktv&channel=umeng","group":"②影视","detail_col_type":"text_1","detail_find_rule":"","sdetail_col_type":"movie_1","sdetail_find_rule":"*","ua":"pc","preRule":"eval(getCryptoJS())\nvar nwtime = parseInt(new Date().getTime() / 1000)+'';\nvar srcKey = \"4954af3c86d8bc0b766afee71503d860\"+nwtime+\"f8dd806a73202456eb6e782c1c4aecfc\";\n\tvar sign = CryptoJS.MD5(srcKey).toString(CryptoJS.enc.Hex);\nputVar('kdstime',nwtime);\nputVar('kdskey',sign);","pages":"[]","proxy":"","icon":"http://sj.91kds.cn/favicon.ico"}